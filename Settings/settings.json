{
  // ========================
  // 🎨 Editor Appearance
  // ========================
  "editor.fontFamily": "'Hack Nerd Font Mono', 'Cascadia Code', 'Consolas', monospace",
  "editor.fontLigatures": true,
  "editor.fontSize": 14,
  "editor.cursorBlinking": "phase",
  "editor.cursorSmoothCaretAnimation": "on",
  "editor.cursorStyle": "line-thin",
  "editor.minimap.renderCharacters": false,

  // ========================
  // 🧠 Workbench UI
  // ========================
  "workbench.colorTheme": "One Dark Pro Flat",
  "workbench.iconTheme": "material-icon-theme",
  "workbench.productIconTheme": "fluent-icons",
  "workbench.activityBar.location": "top",
  "workbench.statusBar.visible": false,
  "workbench.secondarySideBar.defaultVisibility": "hidden",
  "workbench.startupEditor": "none",
  "workbench.editor.empty.hint": "hidden",
  "workbench.panel.showLabels": false,

  // ========================
  // 📁 Explorer
  // ========================
  "files.exclude": {
    "**/*.class": true
  },
  "explorer.compactFolders": false,

  // ========================
  // 💻 Terminal
  // ========================
  "terminal.integrated.fontFamily": "'Hack Nerd Font Mono', 'Cascadia Code', monospace",
  "terminal.integrated.fontSize": 13,
  "terminal.integrated.lineHeight": 1.1,
  "terminal.integrated.initialHint": false,
  "terminal.integrated.defaultProfile.windows": "PowerShell",

  "terminal.integrated.profiles.windows": {
    "PowerShell": {
      // pwsh se resuelve automáticamente si está en PATH
      "source": "PowerShell"
    },
    "Command Prompt": {
      "path": "${env:windir}\\System32\\cmd.exe",
      "args": [],
      "icon": "terminal-cmd"
    },
    "Git Bash": {
      "path": "C:\\Program Files\\Git\\bin\\bash.exe",
      "args": ["--login", "-i"]
    }
  },

  // ========================
  // 🎨 Theme Overrides
  // ========================
  "workbench.colorCustomizations": {
    "editorCursor.foreground": "#FFFFFF",
    "terminalCursor.foreground": "#FFFFFF",
    "terminalCursor.background": "#000000",
    "terminal.foreground": "#CCCCCC"
  },

  // ========================
  // ▶️ Code Runner
  // ========================
  "code-runner.runInTerminal": true,
  "code-runner.executorMap": {
    "javascript": "node",
    "java": "clear; cd $dir && javac $fileName && java $fileNameWithoutExt",
    "c": "cd $dir && gcc $fileName -o $fileNameWithoutExt && $dir$fileNameWithoutExt",
    "cpp": "cd $dir && g++ $fileName -o $fileNameWithoutExt && $dir$fileNameWithoutExt",
    "zig": "zig run",
    "php": "php",
    "python": "python -u",
    "powershell": "powershell -ExecutionPolicy ByPass -File",
    "bat": "cmd /c",
    "shellscript": "bash"
  },

  // ========================
  // 🧾 Formatting
  // ========================
  "[html]": { "editor.defaultFormatter": "esbenp.prettier-vscode" },
  "[css]": { "editor.defaultFormatter": "esbenp.prettier-vscode" },
  "[javascript]": { "editor.defaultFormatter": "esbenp.prettier-vscode" },
  "[javascriptreact]": { "editor.defaultFormatter": "esbenp.prettier-vscode" },
  "[typescript]": { "editor.defaultFormatter": "esbenp.prettier-vscode" },
  "[typescriptreact]": { "editor.defaultFormatter": "esbenp.prettier-vscode" },
  "[java]": { "editor.defaultFormatter": "Oracle.oracle-java" },

  // ========================
  // ⚙️ System / Behavior
  // ========================
  "security.workspace.trust.untrustedFiles": "open",
  "diffEditor.ignoreTrimWhitespace": false,
  "editor.codeActionsOnSave": {},
  "javascript.updateImportsOnFileMove.enabled": "always",
  "chat.tools.terminal.simpleCollapsible": false,

  // ========================
  // 🔕 Telemetry / Noise
  // ========================
  "jdk.telemetry.enabled": false,
  "redhat.telemetry.enabled": false,
  "update.showReleaseNotes": false,

  // ========================
  // 🤖 AI / GitLens
  // ========================
  "gitlens.ai.model": "vscode",
  "gitlens.ai.vscode.model": "copilot:gpt-4.1",
  "chat.disableAIFeatures": true,

  // ========================
  // ✨ Animations / Effects
  // ========================
  "animations.Enabled": true,
  "animations.Command-Palette": "None",
  "animations.Tabs": "Slide",
  "animations.Active": "Indent",
  "animations.CursorAnimation": false,

  // ⚠️ vscode_custom_css.imports requiere configuración local por dispositivo.
  // Agrega esta línea solo en el settings LOCAL de cada máquina, no en el sync.
  // "vscode_custom_css.imports": ["file:///c:/Users/TU_USUARIO/..."],

  "git.autofetch": true
}